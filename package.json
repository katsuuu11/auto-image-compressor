{
  "name": "image-compressor-electron",
  "version": "1.0.0",
  "description": "Menu bar Electron app for automatic image compression",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "sharp": "^0.33.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourcompany.image-compressor",
    "productName": "ImageCompressor",
    "files": [
      "**/*",
      "!node_modules/.bin",
      "!dist/**/*"
    ],
    "asar": true,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64",
            "universal"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "title": "ImageCompressor Installer"
    }
  }
}
